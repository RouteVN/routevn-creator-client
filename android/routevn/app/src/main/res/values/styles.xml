<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.RouteVNCreator" parent="@android:style/Theme.Material.NoActionBar">
        <item name="android:fontFamily">sans</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
        <item name="android:windowBackground">@color/routevn_background</item>
        <item name="android:statusBarColor">@color/routevn_background</item>
        <item name="android:navigationBarColor">@color/routevn_background</item>
        <item name="android:colorAccent">@color/routevn_foreground</item>
    </style>

    <style name="Theme.RouteVNCreator.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/routevn_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_icon</item>
        <item name="windowSplashScreenIconBackgroundColor">@color/routevn_background</item>
        <item name="postSplashScreenTheme">@style/Theme.RouteVNCreator</item>
        <item name="android:statusBarColor">@color/routevn_background</item>
        <item name="android:navigationBarColor">@color/routevn_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar">false</item>
    </style>
</resources>
