{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RouteVN Shell",
  "version": "0.1.0",
  "identifier": "vn.routevn.shell",
  "build": {
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "",
        "width": 1600,
        "height": 930,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "dragDropEnabled": false,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
