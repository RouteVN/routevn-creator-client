{
  "name": "routevn-creator-client",
  "description": "A visual novel engine and creator tool for building interactive narrative games with branching storylines, character dialogues, and multimedia support",
  "homepage": "https://routevn.com/creator/about/",
  "keywords": [
    "game-engine",
    "visual-novel",
    "visual-novel-games",
    "visual-novel-engine",
    "interactive-fiction-engine",
    "visual-novel-maker",
    "visual-novel-framework",
    "visual-novel-editor",
    "visual-novel-tools",
    "visual-novel-creator"
  ],
  "type": "module",
  "dependencies": {
    "@lexical/history": "0.22.0",
    "@lexical/rich-text": "0.22.0",
    "@lexical/selection": "0.22.0",
    "@lexical/utils": "0.22.0",
    "@rettangoli/fe": "1.1.3",
    "@rettangoli/ui": "1.7.6",
    "@rettangoli/vt": "1.0.5",
    "@routevn/creator-model": "file:../routevn-creator-model",
    "@tauri-apps/api": "2.11.0",
    "@tauri-apps/plugin-dialog": "2.4.2",
    "@tauri-apps/plugin-fs": "2.5.1",
    "@tauri-apps/plugin-opener": "2.5.4",
    "@tauri-apps/plugin-process": "2.3.1",
    "@tauri-apps/plugin-sql": "2.3.1",
    "@tauri-apps/plugin-updater": "2.10.1",
    "file-type": "21.3.4",
    "immer": "10.2.0",
    "insieme": "2.1.1",
    "jempl": "1.0.0",
    "js-yaml": "4.1.1",
    "jsdom": "26.1.0",
    "jszip": "3.10.1",
    "lexical": "0.22.0",
    "nanoid": "5.1.11",
    "route-engine-js": "1.26.1",
    "route-graphics": "1.24.0",
    "rxjs": "7.8.2",
    "snabbdom": "3.6.3",
    "snabbdom-to-html": "7.1.0",
    "vite": "6.4.2"
  },
  "scripts": {
    "build:bundle": "vite build --config scripts/vite.bundle.config.js",
    "build:web": "./scripts/build.sh web",
    "build:tauri": "./scripts/build.sh tauri",
    "build:android": "./scripts/build.sh android",
    "build:android:assets": "node scripts/build-android-assets.js",
    "watch:web": "rtgl fe watch -s src/setup.web.js",
    "watch:tauri": "rtgl fe watch -s src/setup.tauri.js",
    "android:install": "bun run build:android && cd android/routevn && ./gradlew installDebug",
    "android:bundle": "bun run build:android && cd android/routevn && ./gradlew bundleRelease",
    "test": "node scripts/test.js",
    "test:smoke": "node scripts/test-smoke.js",
    "test:export-bundle": "node scripts/test-export-bundle-pipeline.js",
    "test:convergence": "node scripts/test-convergence.js",
    "test:integration": "node scripts/test-integration.js",
    "test:collab-adapters": "node scripts/test-collab-adapters.js",
    "test:puty": "vitest run tests/puty",
    "test:mobile-keyboard:android": "node scripts/mobile-keyboard-screenshot-android.js",
    "check:contracts": "rtgl check --dir src/components --dir src/pages",
    "vt:generate": "bun run build:web && bash ./scripts/run-vt-docker.sh vt screenshot",
    "vt:docker": "bun run vt:generate",
    "vt:report": "bun run vt:generate && bash ./scripts/run-vt-docker.sh vt report",
    "vt:accept": "bash ./scripts/run-vt-docker.sh vt accept",
    "vt:serve": "bunx serve .rettangoli/vt/_site -p 3002",
    "serve": "bunx serve _site -p 3001",
    "lint": "oxlint && bun prettier --check src",
    "lint:fix": "oxlint && bun prettier --check --write src",
    "prepare": "husky",
    "tauri": "tauri",
    "tauri:dev:linux": "tauri dev --target $(rustc --print host-tuple)",
    "tauri:dev:mac": "tauri dev --target aarch64-apple-darwin",
    "tauri:dev:win": "CARGO_BUILD_JOBS=2 tauri dev --runner ../scripts/tauri-wsl-windows-runner.sh --target x86_64-pc-windows-msvc",
    "tauri:build": "bun run build:tauri && tauri build --config src-tauri/tauri.prod.conf.json",
    "tauri:build:appimage": "./scripts/tauri-build-appimage.sh",
    "tauri:build:win": "bun run build:tauri && tauri build --config src-tauri/tauri.prod.conf.json --runner cargo-xwin --target x86_64-pc-windows-msvc",
    "tauri:build:win:steam": "./scripts/tauri-build-win-steam.sh",
    "tauri:build:mac": "./scripts/tauri-build-mac.sh",
    "tauri:build:mac:steam": "./scripts/tauri-build-mac-steam.sh",
    "tauri:build:linux:steam": "./scripts/tauri-build-linux-steam.sh"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.11.1",
    "better-sqlite3": "12.10.0",
    "husky": "9.1.7",
    "lint-staged": "16.4.0",
    "oxlint": "1.65.0",
    "prettier": "3.6.2",
    "puty": "0.1.2",
    "vitest": "3.2.4"
  },
  "overrides": {
    "@tauri-apps/api": "2.11.0",
    "liquidjs": "10.27.0",
    "picomatch": "4.0.4",
    "postcss": "8.5.14",
    "rollup": "4.60.4",
    "vite": "6.4.2",
    "yaml": "2.9.0"
  },
  "lint-staged": {
    "src/**/*.{js}": [
      "oxlint && bun prettier --write"
    ]
  }
}
