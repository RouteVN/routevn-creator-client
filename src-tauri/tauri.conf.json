{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "RouteVN Creator",
  "mainBinaryName": "routevn-creator",
  "version": "1.10.2",
  "identifier": "com.routevn.creator",
  "build": {
    "frontendDist": "../_site",
    "devUrl": "http://localhost:3001",
    "runner": "cargo"
  },
  "app": {
    "windows": [
      {
        "title": "RouteVN Creator",
        "width": 1600,
        "height": 930,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": {
        "default-src": [
          "'self'",
          "'unsafe-eval'",
          "ipc:",
          "http://ipc.localhost"
        ],
        "connect-src": [
          "'self'",
          "ipc:",
          "http://ipc.localhost",
          "http://127.0.0.1:*",
          "blob:",
          "data:",
          "asset:",
          "asset://localhost",
          "http://asset.localhost",
          "project-file:",
          "http://project-file.localhost"
        ],
        "style-src": ["'self'", "'unsafe-inline'"],
        "img-src": [
          "'self'",
          "http://127.0.0.1:*",
          "asset:",
          "http://asset.localhost",
          "project-file:",
          "http://project-file.localhost",
          "data:",
          "blob:"
        ],
        "media-src": [
          "'self'",
          "http://127.0.0.1:*",
          "asset:",
          "http://asset.localhost",
          "project-file:",
          "http://project-file.localhost",
          "blob:"
        ],
        "font-src": ["'self'", "asset:", "http://asset.localhost", "blob:"],
        "script-src": ["'self'", "'unsafe-eval'", "'wasm-unsafe-eval'"],
        "worker-src": ["'self'", "blob:"]
      },
      "dangerousDisableAssetCspModification": false,
      "devCsp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**/*"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "nsis",
    "publisher": "Yuusoft",
    "homepage": "https://routevn.com",
    "copyright": "Copyright (c) 2026 Yuusoft",
    "license": "MIT",
    "category": "GraphicsAndDesign",
    "shortDescription": "RouteVN Creator",
    "longDescription": "RouteVN Creator. Follow us on social media to stay updated.",
    "resources": {
      "assets/player-templates/windows/RouteVNPlayerTemplate.exe": "player-templates/windows/RouteVNPlayerTemplate.exe",
      "assets/player-templates/macos/RouteVNPlayerTemplate.app.zip": "player-templates/macos/RouteVNPlayerTemplate.app.zip"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true,
    "licenseFile": "assets/LICENSE.txt",
    "linux": {
      "appimage": {
        "bundleMediaFramework": true
      }
    },
    "macOS": {
      "dmg": {
        "windowSize": {
          "width": 660,
          "height": 400
        },
        "appPosition": {
          "x": 180,
          "y": 170
        },
        "applicationFolderPosition": {
          "x": 480,
          "y": 170
        }
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDM4ODJGRjUyRTg5NDBFRDcKUldUWERwVG9VditDT0gyQTNEWmV3Q0RqUElnUW54aGs0NDhGNGdtL0JvZW00SEdZeDh5ZFl4UnkK",
      "endpoints": [
        "http://127.0.0.1:8787/tauri/update?target={{target}}&arch={{arch}}&currentVersion={{current_version}}"
      ],
      "windows": {
        "installMode": "passive"
      },
      "dangerousInsecureTransportProtocol": true
    }
  }
}
