# Maintainer: RouteVN Team

pkgname=routevn-creator
pkgver=1.7.2
pkgrel=1
pkgdesc="Free and Open Source tool to create Visual Novels without any coding."
arch=("x86_64")
url="https://routevn.com"
license=("MIT")
depends=(
  "gtk3"
  "hicolor-icon-theme"
  "libayatana-appindicator"
  "librsvg"
  "openssl"
  "sqlite"
  "webkit2gtk-4.1"
  "xdg-utils"
)
makedepends=(
  "bun"
  "pkgconf"
  "rust"
)
optdepends=(
  "gst-libav: MP4/H.264 media playback"
  "gst-plugins-good: common GStreamer media codecs"
  "gst-plugins-bad: additional GStreamer media codecs"
  "gst-plugins-ugly: patent-encumbered GStreamer media codecs"
)
source=("${pkgname}-${pkgver}::git+https://github.com/RouteVN/routevn-creator-client.git#tag=v${pkgver}")
sha256sums=("SKIP")

build() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  bun install --frozen-lockfile
  bun run build:tauri
  bun run tauri build --config src-tauri/tauri.prod.conf.json --no-bundle --ci
}

package() {
  cd "${srcdir}/${pkgname}-${pkgver}"

  install -Dm755 "src-tauri/target/release/routevn-creator" \
    "${pkgdir}/usr/bin/routevn-creator"

  install -Dm644 "src-tauri/icons/32x32.png" \
    "${pkgdir}/usr/share/icons/hicolor/32x32/apps/routevn-creator.png"
  install -Dm644 "src-tauri/icons/128x128.png" \
    "${pkgdir}/usr/share/icons/hicolor/128x128/apps/routevn-creator.png"
  install -Dm644 "src-tauri/icons/128x128@2x.png" \
    "${pkgdir}/usr/share/icons/hicolor/256x256@2/apps/routevn-creator.png"
  install -Dm644 "src-tauri/icons/icon.png" \
    "${pkgdir}/usr/share/icons/hicolor/512x512/apps/routevn-creator.png"

  install -Dm644 "src-tauri/assets/com.routevn.creator.metainfo.xml" \
    "${pkgdir}/usr/share/metainfo/com.routevn.creator.metainfo.xml"
  install -Dm644 "src-tauri/assets/LICENSE.txt" \
    "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

  install -Dm644 /dev/stdin \
    "${pkgdir}/usr/share/applications/routevn-creator.desktop" <<'EOF'
[Desktop Entry]
Categories=Graphics;
Comment=Create Visual Novels without any coding
Exec=routevn-creator
StartupWMClass=routevn-creator
Icon=routevn-creator
Name=RouteVN Creator
Terminal=false
Type=Application
EOF
}
